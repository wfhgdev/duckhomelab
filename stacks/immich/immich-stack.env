# ============================================================================
# .env — Variables de entorno para el stack de Immich
# Ubicación: /opt/stacks/immich/.env
#
# IMPORTANTE: este archivo debe estar en el mismo directorio que
# docker-compose.yml para que Compose lo cargue automáticamente.
# ============================================================================

# ----------------------------------------------------------------------------
# VERSIÓN DE IMMICH
# 'v2' apunta siempre a la última versión estable de la rama mayor 2.x,
# sin riesgo de saltos a versiones mayores con cambios que rompan la config.
# Para fijar una versión exacta usa: IMMICH_VERSION=v2.17.0
# ----------------------------------------------------------------------------
IMMICH_VERSION=v2

# ----------------------------------------------------------------------------
# ZONA HORARIA EJEMPLOS: America/Bogota
# ----------------------------------------------------------------------------
TZ=Europe/Madrid

# ----------------------------------------------------------------------------
# ALMACENAMIENTO DE FOTOS Y VÍDEOS
# Ruta en el host donde se guardarán los archivos subidos por los usuarios.
# Con la configuración actual apunta a /opt/stacks/immich/library
# ----------------------------------------------------------------------------
UPLOAD_LOCATION=/opt/stacks/immich/library

# ----------------------------------------------------------------------------
# ALMACENAMIENTO DE LA BASE DE DATOS
# IMPORTANTE: debe estar en un filesystem que soporte permisos Unix
# (ext4, zfs, btrfs, xfs). NO uses NTFS, FAT32 ni NAS shares de Windows.
# ----------------------------------------------------------------------------
DB_DATA_LOCATION=/opt/stacks/immich/postgres

# ----------------------------------------------------------------------------
# MACHINE LEARNING
#
# ESTADO ACTUAL: DESHABILITADO
#
# Esta variable le dice a immich-server que no intente conectarse al
# servicio de machine learning. Sin ella, aunque el contenedor esté
# comentado en el compose, Immich mostrará errores de conexión en los logs.
#
# Para REACTIVAR el machine learning:
#   1. Comenta o elimina esta línea (añade '#' delante).
#   2. Descomenta el bloque 'immich-machine-learning' en docker-compose.yml.
#   3. Ejecuta: docker compose up -d
# ----------------------------------------------------------------------------
IMMICH_MACHINE_LEARNING_ENABLED=false

# ----------------------------------------------------------------------------
# CREDENCIALES DE POSTGRESQL
# DB_PASSWORD: cámbialo por una contraseña segura antes de desplegar.
# Usa solo caracteres A-Za-z0-9 (sin espacios ni caracteres especiales)
# para evitar problemas de parsing en Docker.
# Postgres NO está expuesto al exterior, esta contraseña es solo interna.
# ----------------------------------------------------------------------------
DB_PASSWORD=Cambiar por una contraseña segura
DB_USERNAME=postgres
DB_DATABASE_NAME=immich
